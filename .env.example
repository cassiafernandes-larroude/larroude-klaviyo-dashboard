# Klaviyo Private API Key
# Crie em: https://www.klaviyo.com/settings/account/api-keys
# Escopos read necessários: Flows, Segments, Metrics, Accounts, Events
KLAVIYO_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Secret para validar requests do Vercel Cron
# Gere um valor random — Vercel envia esse header quando dispara o cron
CRON_SECRET=
